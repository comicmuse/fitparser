# Stryd credentials
STRYD_EMAIL=
STRYD_PASSWORD=

# LLM Provider — configure exactly ONE of the sections below.
# If more than one provider is configured, OpenAI is used and a warning is logged.

# OpenAI (default)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic Claude (alternative — comment out OpenAI block above if using this)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-6

# Ollama — local models (alternative — comment out other blocks above if using this)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_NUM_CTX=16384

# Set to false to disable automatic analysis in the pipeline (sync/parse still run).
# On-demand analysis from the web UI is always available regardless of this setting.
LLM_AUTO_ANALYSE=true

# Paths
DATA_DIR=./data

# Sync schedule. 0 to disable scheduled syncing (manual sync from web UI, and via Strava webhooks still works).
SYNC_INTERVAL_HOURS=0
SYNC_LOOKBACK_DAYS=30

# Timezone for FIT parsing
TIMEZONE=Europe/London

# Flask
FLASK_PORT=5000
FLASK_DEBUG=false
# Used for Flask sessions and JWT signing. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Default password for "athlete" user (change this!)
RUNCOACH_PASSWORD=runcoach123

# Only auto-analyze runs on or after this date (YYYY-MM-DD)
# Leave empty to analyze all parsed runs
ANALYZE_FROM=

# Strava Integration (optional)
# Create an app at https://www.strava.com/settings/api
# Set the Authorization Callback Domain to your server's domain
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# A random string you choose — used to verify webhook subscription ownership
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
STRAVA_WEBHOOK_VERIFY_TOKEN=
# Set to false in development (Strava can't reach localhost to register)
STRAVA_WEBHOOK_ENABLED=true
